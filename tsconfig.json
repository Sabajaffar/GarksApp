{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "skipLibCheck": true,
    "allowJs": true,
    "jsx": "react-native",
    "resolveJsonModule": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "App.tsx",
    "index.js",
    ".expo/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "capacitor.config.ts",
    "vite.config.ts",
    "server.ts",
    "src/main.tsx",
    "src/App.tsx",
    "src/layouts",
    "src/pages/About.tsx",
    "src/pages/Privacy.tsx",
    "src/pages/PrivacyPolicy.tsx"
  ]
}
